#!/bin/sh
set -eu

source_path="$0"

while [ -L "$source_path" ]; do
  source_dir="$(CDPATH= cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)"
  linked_path="$(readlink "$source_path")"

  case "$linked_path" in
    /*) source_path="$linked_path" ;;
    *) source_path="$source_dir/$linked_path" ;;
  esac
done

script_dir="$(CDPATH= cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)"
app_path="$(CDPATH= cd -P "$script_dir/../../../.." >/dev/null 2>&1 && pwd)"

codiff_version() {
  sed -n 's/^  "version": "\([^"]*\)".*/\1/p' "$script_dir/../package.json"
}

show_help() {
  version="$(codiff_version)"
  blue_bold="$(printf '\033[1;34m')"
  gray="$(printf '\033[90m')"
  reset="$(printf '\033[0m')"

  printf '%s\n' "${blue_bold}codiff v${version}${reset} ${gray}A fast local diff viewer.${reset}"
  printf '\n'
  printf '%s\n' "${blue_bold}Usage:${reset} ${gray}codiff [options] [<ref> | <pr> | <url>] [path]${reset}"
  printf '\n'
  printf '%s\n' "${blue_bold}Options:${reset}"
  printf '  %-22s%s%s%s\n' "--commit <ref>" "$gray" "Review a specific commit." "$reset"
  printf '  %-22s%s%s%s\n' "--codex-session <id>" "$gray" "Attach Codex session metadata to a walkthrough." "$reset"
  printf '  %-22s%s%s%s\n' "--help, -h" "$gray" "Show this help message and exit." "$reset"
  printf '  %-22s%s%s%s\n' "--version, -v" "$gray" "Show version number and exit." "$reset"
  printf '  %-22s%s%s%s\n' "--walkthrough, -w" "$gray" "Start with an LLM-generated review walkthrough." "$reset"
  printf '  %-22s%s%s%s\n' "--walkthrough-context <file>" "$gray" "Seed a walkthrough with Codex conversation context JSON." "$reset"
  printf '\n'
  printf '%s\n' "${blue_bold}Examples:${reset}"
  printf '  %-22s%s%s%s\n' "codiff" "$gray" "Review staged and unstaged changes." "$reset"
  printf '  %-22s%s%s%s\n' "codiff /path/to/repo" "$gray" "Review changes in a specific repository." "$reset"
  printf '  %-22s%s%s%s\n' "codiff a1b2c3d" "$gray" "Review a specific commit." "$reset"
  printf '  %-22s%s%s%s\n' "codiff '#75'" "$gray" "Review pull request #75." "$reset"
  printf '  %-22s%s%s%s\n' "codiff pr 75" "$gray" "Review pull request #75 (alternate syntax)." "$reset"
  printf '  %-22s%s%s%s\n' "codiff -w" "$gray" "Start with an LLM walkthrough." "$reset"
  printf '  %-22s%s%s%s\n' "codiff -w a1b2c3d" "$gray" "Walkthrough a specific commit." "$reset"
}

repository_path=""
codex_session_id=""
commit_ref=""
pull_request_source=""
walkthrough_context_path=""
expect_codex_session=0
expect_commit_ref=0
expect_pull_request_number=0
expect_walkthrough_context=0
walkthrough=0

is_commit_ref_arg() {
  ref_arg="$1"

  if [ -e "$ref_arg" ]; then
    return 1
  fi

  if printf '%s' "$ref_arg" | grep -Eq '^[0-9a-fA-F]{4,64}$'; then
    return 0
  fi

  if printf '%s' "$ref_arg" | grep -Eq '^(@|HEAD)(([~^][0-9]*)|(\^\{[^}]+\})|(@\{[^}]+\}))*$'; then
    return 0
  fi

  if printf '%s' "$ref_arg" | grep -Eq '(\^|~|@\{[^}]+\})'; then
    return 0
  fi

  return 1
}

for arg in "$@"; do
  if [ "$expect_codex_session" -eq 1 ]; then
    codex_session_id="$arg"
    expect_codex_session=0
    continue
  fi

  if [ "$expect_commit_ref" -eq 1 ]; then
    commit_ref="$arg"
    expect_commit_ref=0
    continue
  fi

  if [ "$expect_walkthrough_context" -eq 1 ]; then
    walkthrough_context_path="$arg"
    expect_walkthrough_context=0
    continue
  fi

  if [ "$expect_pull_request_number" -eq 1 ]; then
    if printf '%s' "$arg" | grep -Eq '^[1-9][0-9]*$'; then
      pull_request_source="#$arg"
      expect_pull_request_number=0
      continue
    fi
    expect_pull_request_number=0
  fi

  case "$arg" in
    --help|-h)
      show_help
      exit 0
      ;;
    --version|-v)
      printf 'codiff v%s\n' "$(codiff_version)"
      exit 0
      ;;
    --walkthrough|-w)
      walkthrough=1
      ;;
    --codex-session)
      expect_codex_session=1
      ;;
    --codex-session=*)
      codex_session_id="${arg#--codex-session=}"
      ;;
    --commit)
      expect_commit_ref=1
      ;;
    --commit=*)
      commit_ref="${arg#--commit=}"
      ;;
    --walkthrough-context)
      expect_walkthrough_context=1
      ;;
    --walkthrough-context=*)
      walkthrough_context_path="${arg#--walkthrough-context=}"
      ;;
    -*)
      ;;
    *)
      if [ -z "$pull_request_source" ] && printf '%s' "$arg" | grep -Eiq '^(pr|pull-request)$'; then
        expect_pull_request_number=1
      elif [ -z "$pull_request_source" ] && printf '%s' "$arg" | grep -Eq '^#[1-9][0-9]*$'; then
        pull_request_source="$arg"
      elif [ -z "$pull_request_source" ] && printf '%s' "$arg" | grep -Eq '^https://github\.com/[^/]+/[^/]+/pull/[0-9]+/?$'; then
        pull_request_source="$arg"
      elif [ -z "$commit_ref" ] && is_commit_ref_arg "$arg"; then
        commit_ref="$arg"
      elif [ -z "$repository_path" ]; then
        repository_path="$arg"
      fi
      ;;
  esac
done

repository_path="${repository_path:-$PWD}"

case "$repository_path" in
  /*) ;;
  *) repository_path="$PWD/$repository_path" ;;
esac

if [ -n "$walkthrough_context_path" ]; then
  case "$walkthrough_context_path" in
    /*) ;;
    *) walkthrough_context_path="$PWD/$walkthrough_context_path" ;;
  esac
fi

open_codiff() {
  if [ -n "$codex_session_id" ] && [ -n "$walkthrough_context_path" ]; then
    open -n "$app_path" --args --codex-session "$codex_session_id" --walkthrough-context "$walkthrough_context_path" "$@"
  elif [ -n "$codex_session_id" ]; then
    open -n "$app_path" --args --codex-session "$codex_session_id" "$@"
  elif [ -n "$walkthrough_context_path" ]; then
    open -n "$app_path" --args --walkthrough-context "$walkthrough_context_path" "$@"
  else
    open -n "$app_path" --args "$@"
  fi
}

if [ -n "$pull_request_source" ] && [ "$walkthrough" -eq 1 ]; then
  open_codiff --walkthrough "$pull_request_source" "$repository_path"
elif [ -n "$pull_request_source" ]; then
  open_codiff "$pull_request_source" "$repository_path"
elif [ -n "$commit_ref" ] && [ "$walkthrough" -eq 1 ]; then
  open_codiff --walkthrough --commit "$commit_ref" "$repository_path"
elif [ -n "$commit_ref" ]; then
  open_codiff --commit "$commit_ref" "$repository_path"
elif [ "$walkthrough" -eq 1 ]; then
  open_codiff --walkthrough "$repository_path"
else
  open_codiff "$repository_path"
fi
